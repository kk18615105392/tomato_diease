.form { margin-top: 40rpx; }
.tabs { display: flex; margin-bottom: 32rpx; background: #f3f4f6; border-radius: 12rpx; padding: 6rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx; border-radius: 10rpx; color: #6b7280; }
.tab.on { background: #fff; color: #14532d; font-weight: 700; }
.field { margin-bottom: 24rpx; }
.label { display: block; margin-bottom: 10rpx; color: #374151; font-size: 26rpx; }
input {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
}
.submit { margin-top: 12rpx; }
.tip { margin-top: 24rpx; text-align: center; }
