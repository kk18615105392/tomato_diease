.title { font-size: 34rpx; font-weight: 700; color: #14532d; margin-bottom: 8rpx; }
.preview {
  width: 100%;
  height: 420rpx;
  border-radius: 16rpx;
  margin: 24rpx 0;
  background: #e5e7eb;
}
.preview.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 26rpx;
}
.actions { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.half { flex: 1; }
.full { width: 100%; }
.btn-ghost {
  background: #ecfdf5;
  color: #166534;
  border-radius: 999rpx;
  font-weight: 600;
}
.btn-ghost::after { border: none; }
