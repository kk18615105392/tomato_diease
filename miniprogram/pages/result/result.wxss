.title { font-size: 34rpx; font-weight: 700; color: #14532d; margin-bottom: 12rpx; }
.list { margin: 24rpx 0; }
.item { padding: 18rpx 0; border-bottom: 1px solid #f3f4f6; }
.row { display: flex; justify-content: space-between; align-items: center; }
.conf { color: #166534; font-weight: 700; }
.big { font-size: 44rpx; font-weight: 700; color: #14532d; margin: 24rpx 0 8rpx; }
.btn-primary, .btn-ghost { margin-top: 16rpx; }
.btn-ghost {
  background: #ecfdf5;
  color: #166534;
  border-radius: 999rpx;
}
.btn-ghost::after { border: none; }
